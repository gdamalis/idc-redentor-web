ENVIRONMENT_NAME=local

# The URL for the domain your app is hosted on (used for generating the urls needed for SEO)
# If you deploy to Vercel or Netlify it is configured through the respective config files (`vercel.json` and `netlify.toml`)
NEXT_PUBLIC_BASE_URL=http://localhost:3000/

# Your current space ID: https://www.contentful.com/help/find-space-id/
CONTENTFUL_SPACE_ID=

# Your current space Content Delivery API access token: https://www.contentful.com/developers/docs/references/content-delivery-api/
CONTENTFUL_ACCESS_TOKEN=

# Your current space Content Preview API access token: https://www.contentful.com/developers/docs/references/content-preview-api/
CONTENTFUL_PREVIEW_ACCESS_TOKEN=

# A unique string used to identify preview requests: https://nextjs.org/docs/advanced-features/preview-mode#securely-accessing-it-from-your-headless-cms
CONTENTFUL_PREVIEW_SECRET=

# Optional. Defaults to the `master` alias. Set to the current work env (e.g. master-1.0.0) locally to test model changes.
# CONTENTFUL_ENVIRONMENT=master

# Contentful Management API (CMA) personal access token. Used by the local
# Contentful MCP server (.mcp.json) so Claude Code agents can read the content model
# and write to the "agent-sandbox" environment, AND by the app runtime's Predica PDF
# regen cron (writes DRAFT-only, production env, never the master alias — see
# docs/architecture/predica-pdf-mirrors-post.md). This is a DIFFERENT token from the
# Delivery/Preview tokens above. Mint it at: Contentful -> Settings -> API keys ->
# Content Management Tokens (Personal Access Tokens).
# Must be exported into the shell that launches Claude Code for .mcp.json to pick it up.
# See docs/contentful-mcp.md.
CONTENTFUL_MANAGEMENT_ACCESS_TOKEN=

# Google Gemini API key. Used ONLY by the /predica harness script
# .claude/scripts/predica/build-predica-featured.mjs to generate the AI background
# for each sermon's featured image (model: gemini-2.5-flash-image). The app runtime
# does NOT use it. OPTIONAL: with no key the script falls back to an on-brand
# typographic card. Mint at https://aistudio.google.com/apikey. See
# docs/predica-featured-image.md.
GEMINI_API_KEY=

# Resend Broadcasts (newsletter broadcast engine — ICR-29)
# Resend Broadcasts — one audience per locale (ICR-44)
RESEND_AUDIENCE_ID_ES_AR=
RESEND_AUDIENCE_ID_EN_US=
# Legacy single audience (optional fallback for es-AR only)
RESEND_AUDIENCE_ID=
BROADCAST_POSTAL_ADDRESS=

# --- Required at runtime but previously missing from this example ---

# Secret the Contentful publish webhook must send (header x-vercel-reval-key) to
# POST /api/revalidate so it can revalidateTag("site-content").
CONTENTFUL_REVALIDATE_SECRET=

# MongoDB connection string. Backs the blog "likes" feature and saved "contact" messages
# (db name: "website"). Server-side only.
MONGODB_URI=

# Transactional email (contact form). Adapter selected by MAIL_PROVIDER: "sendgrid" | "resend".
MAIL_PROVIDER=resend
FROM_EMAIL=
CONTACT_FORM_RECIPIENT_EMAIL=
# Provide the key for whichever MAIL_PROVIDER you use (one is enough):
SENDGRID_API_KEY=
RESEND_API_KEY=

# Shared secret the Contentful draft save/auto_save webhook must send (header
# x-predica-regen-key) to POST /api/predica/regenerate-pdf so it can mark a sermon's
# PDF dirty for regeneration. See docs/architecture/predica-pdf-mirrors-post.md.
PREDICA_REGEN_SECRET=

# Bearer secret Vercel Cron sends (header Authorization: Bearer <value>) to
# GET /api/predica/regenerate-pdf/cron, the debounced job that renders + swaps
# regenerated sermon PDFs.
CRON_SECRET=

# Optional. Seconds of inactivity before the cron considers a dirty sermon PDF job
# eligible for render (debounce window, coalesces bursts of edits). Defaults to 90
# in code if unset.
PDF_REGEN_QUIET_WINDOW_SECONDS=

# Note: VERCEL_ENV is injected automatically by Vercel (used by lib/contentful/draftMode.ts).

# --- Sentry (error & performance monitoring) ---
# Public ingest endpoint. Safe to expose (it is NEXT_PUBLIC_*). When UNSET, Sentry
# is completely inert — the app runs normally and sends nothing.
NEXT_PUBLIC_SENTRY_DSN=

# Overrides the Sentry environment tag. Resolution order (a blank/whitespace-only
# value is treated as unset at each step, so leaving this blank is fine — it falls
# through to the next var, same as if it were absent):
#   NEXT_PUBLIC_SENTRY_ENVIRONMENT ?? NEXT_PUBLIC_VERCEL_ENV ?? VERCEL_ENV ?? "development"
# Set this to `staging` on the staging deploy only — staging is a Vercel custom
# environment whose NEXT_PUBLIC_VERCEL_ENV/VERCEL_ENV is "preview" (same as any PR
# preview), so this override is the only thing that distinguishes it.
NEXT_PUBLIC_SENTRY_ENVIRONMENT=

# Auto-injected by Vercel (production | preview | development) — the browser-readable
# mirror of VERCEL_ENV. Normally left blank locally; do not set by hand on Vercel.
# NEXT_PUBLIC_VERCEL_ENV=

# Build-time source-map upload only. Never read at runtime.
SENTRY_ORG=
SENTRY_PROJECT=

# SECRET. Build-time source-map upload only. Set in Vercel/CI, never committed.
# If absent the build still SUCCEEDS — it just skips the source-map upload.
SENTRY_AUTH_TOKEN=

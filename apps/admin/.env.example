ENVIRONMENT_NAME=local

# --- MongoDB (one connection string per database — ICR-166) ---

# apps/admin reaches TWO databases, each via its own self-contained connection
# string authenticating as its own single-database Atlas user. The DB name rides
# in the URI PATH — there is deliberately no separate DB-name env var. Both URIs
# must set authSource=admin explicitly and maxPoolSize to match this app's
# MongoClient options (10). Neither accessor can read the other's variable.
# See docs/architecture/admin-database.md.
# Do not commit real connection strings here (server-side only, gitignored).

# Congregant PII + admin auth. Path DB must be one of "ministry-admin" (prod),
# "ministry-admin-staging", "ministry-admin-test", "ministry-admin-qa", or
# "ministry-admin-e2e" (non-prod / QA — mirrors .claude/config.json's
# qa.env.*.dbNameAllow), e.g.:
#   mongodb+srv://<host>/ministry-admin?authSource=admin&retryWrites=true&w=majority&maxPoolSize=10
# getAdminDb() fails closed on any other name. Note: the code layer alone no
# longer rejects a prod credential misconfigured to a QA-suffixed name (e.g.
# ministry-admin-test) — the Atlas grant is what enforces that boundary. See
# docs/architecture/admin-database.md.
MONGODB_URI=

# Public-site content (likes, contact) — the admin authors it as a CMS. Reuses
# apps/web's existing website user. Path DB must be one of "website" (prod),
# "website-staging", "website-test", "website-qa", or "website-e2e" (non-prod
# / QA — mirrors .claude/config.json's qa.env.*.dbNameAllow), e.g.:
#   mongodb+srv://<host>/website?authSource=admin&retryWrites=true&w=majority&maxPoolSize=10
# getContentDb() fails closed on any other name.
WEBSITE_MONGODB_URI=

# --- Base URL ---

# Canonical base URL this admin app is hosted on. Set in Vercel for deployed
# environments; only needed locally if a feature needs an absolute URL.
NEXT_PUBLIC_ADMIN_BASE_URL=

# --- Firebase — client SDK (browser-safe) ---
# Config values from the Firebase console: Project settings -> General ->
# Your apps -> Web app -> SDK setup and configuration. These are NOT secrets
# (they identify the project to the browser, same as any public Firebase web
# config) but still ship blank here per the repo's names-only convention.
# Read lazily by src/lib/firebase/client.ts — never at import time.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase — Admin SDK (server-only service account) ---
# From a service account JSON key: Firebase console -> Project settings ->
# Service accounts -> Generate new private key. SECRET — never commit real
# values. FIREBASE_PRIVATE_KEY is stored with literal "\n" escapes in most env
# stores (Vercel included); src/lib/firebase/admin.ts un-escapes it before
# handing it to the SDK. Read lazily — never at import time (server-only.ts).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Email (CP2 auth — forthcoming) ---
# Not wired yet in this checkpoint (ICR-124 CP3). Reserved for the auth email
# flows (invite/reset) landing in CP2 of the auth ticket (ICR-125+). Mirrors
# apps/web's RESEND_API_KEY / FROM_EMAIL — see that app's .env.example.
RESEND_API_KEY=
FROM_EMAIL=

ENVIRONMENT_NAME=local

# The URL for the domain your app is hosted on (used for generating the urls needed for SEO)
# If you deploy to Vercel or Netlify it is configured through the respective config files (`vercel.json` and `netlify.toml`)
NEXT_PUBLIC_BASE_URL=http://localhost:3000/

# Your current space ID: https://www.contentful.com/help/find-space-id/
CONTENTFUL_SPACE_ID=

# Your current space Content Delivery API access token: https://www.contentful.com/developers/docs/references/content-delivery-api/
CONTENTFUL_ACCESS_TOKEN=

# Your current space Content Preview API access token: https://www.contentful.com/developers/docs/references/content-preview-api/
CONTENTFUL_PREVIEW_ACCESS_TOKEN=

# A unique string used to identify preview requests: https://nextjs.org/docs/advanced-features/preview-mode#securely-accessing-it-from-your-headless-cms
CONTENTFUL_PREVIEW_SECRET=

# Optional. Defaults to the `master` alias. Set to the current work env (e.g. master-1.0.0) locally to test model changes.
# CONTENTFUL_ENVIRONMENT=master

# Contentful Management API (CMA) personal access token. Used ONLY by the local
# Contentful MCP server (.mcp.json) so Claude Code agents can read the content model
# and write to the "agent-sandbox" environment. This is a DIFFERENT token from the
# Delivery/Preview tokens above. Mint it at: Contentful -> Settings -> API keys ->
# Content Management Tokens (Personal Access Tokens). The app runtime does NOT use it.
# Must be exported into the shell that launches Claude Code for .mcp.json to pick it up.
# See docs/contentful-mcp.md.
CONTENTFUL_MANAGEMENT_ACCESS_TOKEN=

# Google Gemini API key. Used ONLY by the /predica harness script
# .claude/scripts/predica/build-predica-featured.mjs to generate the AI background
# for each sermon's featured image (model: gemini-2.5-flash-image). The app runtime
# does NOT use it. OPTIONAL: with no key the script falls back to an on-brand
# typographic card. Mint at https://aistudio.google.com/apikey. See
# docs/predica-featured-image.md.
GEMINI_API_KEY=

# Mailchimp API key and audience ID, you need to request that
MAILCHIMP_API_KEY=
MAILCHIMP_API_SERVER=
MAILCHIMP_AUDIENCE_ID=

# --- Required at runtime but previously missing from this example ---

# Secret the Contentful publish webhook must send (header x-vercel-reval-key) to
# POST /api/revalidate so it can revalidateTag("site-content").
CONTENTFUL_REVALIDATE_SECRET=

# MongoDB connection string. Backs the blog "likes" feature and saved "contact" messages
# (db name: "website"). Server-side only.
MONGODB_URI=

# Transactional email (contact form). Adapter selected by MAIL_PROVIDER: "sendgrid" | "resend".
MAIL_PROVIDER=resend
FROM_EMAIL=
CONTACT_FORM_RECIPIENT_EMAIL=
# Provide the key for whichever MAIL_PROVIDER you use (one is enough):
SENDGRID_API_KEY=
RESEND_API_KEY=

# Note: VERCEL_ENV is injected automatically by Vercel (used by lib/contentful/draftMode.ts).
